#!/usr/bin/with-contenv bashio
# ==============================================================================
# Start the BookStack RAG FastAPI server
# ==============================================================================

bashio::log.info "Starting BookStack RAG API on port 8000..."

cd /app

exec python3 -m uvicorn \
    --factory app.main:create_app \
    --host 0.0.0.0 \
    --port 8000
